# Copy this file to .env and fill in your values

# Azure OpenAI API
AZURE_OPENAI_API_BASE=https://<your-endpoint>/stg/v1
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_ENDPOINT=https://<your-endpoint>/stg/v1
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_CLIENT_SECRET=<your-client-secret>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>

# Nano Banana (Gemini VLM) — used for multimodal KG image matching
NANO_BANANA_URL=https://<your-endpoint>/vertexai/v1/projects/<project>/locations/any/publishers/google/models/gemini-2.5-flash-image:generateContent
NANO_BANANA_PRO_URL=https://<your-endpoint>/vertexai/v1/projects/<project>/locations/any/publishers/google/models/gemini-3-pro-image-preview:generateContent
NANO_BANANA_FLASH_URL=https://<your-endpoint>/vertexai/v1/projects/<project>/locations/any/publishers/google/models/gemini-2.5-flash:generateContent

# Neo4j — used for multimodal KG storage
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# Request headers for GenAI platform
HEADERS_USERID=<your-email>
HEADERS_PROJECT_NAME=<your-project-name>

# Search
TAVILY_API_KEY=<your-tavily-key>

# Tracing (optional)
LANGSMITH_API_KEY=<your-langsmith-key>
LANGSMITH_PROJECT=deep_research_from_scratch
LANGFUSE_SECRET_KEY=<your-langfuse-secret>
LANGFUSE_PUBLIC_KEY=<your-langfuse-public>
LANGFUSE_BASE_URL=http://localhost:3000
